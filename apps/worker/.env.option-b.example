# Option B — PC worker against KVM Postgres/Redis via SSH tunnel (scripts/ssh-tunnel-kvm.ps1).
# Copy to apps/worker/.env and paste CREDENTIALS_MASTER_KEY + AUTOMATION_INTERNAL_SECRET from KVM:
#   grep CREDENTIALS_MASTER_KEY /opt/automation/.env
#   grep AUTOMATION_INTERNAL_SECRET /opt/automation/.env
# Use POSTGRES_PASSWORD from KVM .env in DATABASE_URL below.

DATABASE_URL=postgresql://postgres:POSTGRES_PASSWORD@localhost:32459/gdms?schema=public
REDIS_URL=redis://localhost:6380
CREDENTIALS_MASTER_KEY=PASTE_FROM_KVM
AUTOMATION_INTERNAL_SECRET=PASTE_FROM_KVM
AUTOMATION_SERVICE_URL=http://127.0.0.1:4101
AI_SERVICE_URL=http://127.0.0.1:4200
AI_INTERNAL_SECRET=PASTE_FROM_KVM_IF_NEEDED
GDMS_BASE_URL=https://ndms.hmil.net/cmm/cmmi/selectLoginMain.dms
