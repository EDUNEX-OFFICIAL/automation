# Local dev (Node on host; run `pnpm docker:up` from repo root for Postgres + Redis).
# Option B (PC worker + KVM Redis via SSH tunnel): see .env.option-b.example and README § Option B.
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/gdms?schema=public
REDIS_URL=redis://localhost:6380
CREDENTIALS_MASTER_KEY=PASTE_BASE64_32_BYTES
AUTOMATION_SERVICE_URL=http://127.0.0.1:4101
AUTOMATION_INTERNAL_SECRET=dev-internal-secret-change-me
AI_SERVICE_URL=http://127.0.0.1:4200
AI_INTERNAL_SECRET=dev-ai-secret-change-me

# Exact GDMS login page (gdms_login default workflow opens this URL).
GDMS_BASE_URL=https://ndms.hmil.net/cmm/cmmi/selectLoginMain.dms

# Required for inquiry_fetch (the login *.dms URL is not the list page).
# GDMS_INQUIRY_LIST_URL=https://ndms.hmil.net/...

# Optional HMIL/Hyundai login DOM overrides (defaults use Playwright placeholders + exact text).
# GDMS_SEL_LOGIN_USER=pw:ph|User ID
# GDMS_SEL_LOGIN_PASS=pw:ph|Password
# GDMS_SEL_OTP_SEND=pw:btn|Send OTP
# GDMS_SEL_OTP_INPUT=pw:ph|Enter OTP
# GDMS_SEL_FINAL_LOGIN=pw:btn|Login

# --- Inside full Docker Compose stack (service DNS names), use instead:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gdms?schema=public
# REDIS_URL=redis://redis:6379
# AUTOMATION_SERVICE_URL=http://automation:4101
# AI_SERVICE_URL=http://ai:4200
