# Option B — PC automation (headed browser on your desktop), KVM Redis/DB via tunnel.
# Copy to apps/automation-service/.env — match AUTOMATION_INTERNAL_SECRET with KVM .env.

DATABASE_URL=postgresql://postgres:POSTGRES_PASSWORD@localhost:54322/gdms?schema=public
REDIS_URL=redis://localhost:6380
PORT=4101
SESSIONS_DIR=./data/sessions
GDMS_BASE_URL=https://ndms.hmil.net/cmm/cmmi/selectLoginMain.dms
AUTOMATION_INTERNAL_SECRET=PASTE_FROM_KVM
PLAYWRIGHT_HEADED=true
