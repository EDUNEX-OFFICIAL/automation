# Local dev (Node on host; `pnpm docker:up` from repo root).
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/gdms?schema=public
REDIS_URL=redis://localhost:6380
PORT=4101
SESSIONS_DIR=./data/sessions

# Must match worker — browser opens this URL when workflow has no per-step URL.
GDMS_BASE_URL=https://ndms.hmil.net/cmm/cmmi/selectLoginMain.dms

AUTOMATION_INTERNAL_SECRET=dev-internal-secret-change-me
# Enquiry transfer requires a visible Chromium window on the automation host.
PLAYWRIGHT_HEADED=true

# --- Docker Compose (all services in containers):
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gdms?schema=public
# REDIS_URL=redis://redis:6379
# SESSIONS_DIR=/data/sessions

# Comma-separated substrings (title + body) that mean GDMS session expired
# GDMS_SESSION_TIMEOUT_PATTERNS=session timeout,session expired

# Optional logout control on GDMS (pw:btn|Logout or CSS selector).
# When unset, auto-detects GDMS 2.0 bottom-left sidebar power/logout (last sidebar button).
# GDMS_SEL_LOGOUT=pw:btn|Logout

# Enquiry transfer — human-like delays (milliseconds)
# GDMS_MICRO_DELAY_MIN_MS=300
# GDMS_MICRO_DELAY_MAX_MS=1500
# GDMS_ACTION_DELAY_MIN_MS=2000
# GDMS_ACTION_DELAY_MAX_MS=6000
# GDMS_SEARCH_INTERVAL_MIN_MS=20000
# GDMS_SEARCH_INTERVAL_MAX_MS=45000
# 0 = poll until Stop (recommended)
# GDMS_ENQUIRY_SEARCH_TIMEOUT_MS=0
# GDMS_SAVE_RETRY_INTERVAL_MS=4000
# GDMS_SAVE_MAX_ATTEMPTS=10

# Keep browser open after failure for manual OTP + Retry transfer (default: true when PLAYWRIGHT_HEADED=true)
# GDMS_KEEP_BROWSER_ON_FAILURE=true

# Optional CSS selector for Customer Enquiry (car) — tried after nav_sal; must open flyout
# GDMS_SEL_CAR_SIDEBAR=
# Built-in first: li.nav_sal → flyout "Customer Enquiry Mgt" → tree "Customer Enquiry" → enquiry list
# Built-in first: [class*="nav_sal"] on selectHome left rail (all frames), flyout-verified
# Block mouse/keyboard on the visible GDMS Chromium window during automation (default true)
# GDMS_BLOCK_USER_INPUT=true

# Write left-rail DOM candidate JSON under SESSIONS_DIR/dom-dumps/ (dashboard ready + car-click fail)
# GDMS_DUMP_DOM=true

# Optional session cookies (JSON array) — NEVER commit real values. Applied when profile is empty or GDMS_FORCE_COOKIE_BOOTSTRAP=true
# GDMS_BOOTSTRAP_COOKIES=[{"name":"JSESSIONID","value":"…","domain":".hmil.net","path":"/"}]
# GDMS_FORCE_COOKIE_BOOTSTRAP=false
