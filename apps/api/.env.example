# API
# NOTE: Agar `localhost:4000` pe koi aur app (e.g. Nest) chal rahi ho, yahan PORT badlo (e.g. 4010) aur
# apps/web me API_UPSTREAM_URL + NEXT_PUBLIC_SOCKET_URL usi port par rakho. Browser me test hamesha:
# `http://127.0.0.1:<PORT>/health` → `service":"gdms-api"` dikhna chahiye.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gdms?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-at-least-32-chars-secret-value
REFRESH_TOKEN_SECRET=replace-with-another-32-chars-secret
CREDENTIALS_MASTER_KEY=PASTE_BASE64_32_BYTES_HERE
CORS_ORIGIN=http://localhost:3000
# Development default true (see packages/shared apiEnvSchema): POST /v1/auth/login with {} → first user.
# Production: set true only if you want empty-body login (risky). Otherwise use NODE_ENV=development locally.
# AUTH_DEV_OPEN_LOGIN=true
AUTOMATION_INTERNAL_SECRET=dev-internal-secret-change-me
AI_INTERNAL_SECRET=dev-ai-secret-change-me
