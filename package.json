{
  "name": "gdms-automation-saas",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @gdms/database exec prisma generate",
    "db:push": "pnpm --filter @gdms/database exec prisma db push",
    "db:migrate": "pnpm --filter @gdms/database exec prisma migrate dev --name init",
    "db:studio": "pnpm --filter @gdms/database exec prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
