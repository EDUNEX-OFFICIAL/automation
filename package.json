{
  "name": "gdms-automation-saas",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "node scripts/prisma-generate.mjs && turbo run build",
    "docker:up": "docker compose up -d postgres redis",
    "dev": "turbo run dev --parallel",
    "dev:local-agent": "turbo run dev --parallel --filter=@gdms/worker --filter=@gdms/automation-service",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:push": "pnpm --filter @gdms/database exec prisma db push",
    "db:migrate": "pnpm --filter @gdms/database exec prisma migrate dev --name init",
    "db:studio": "pnpm --filter @gdms/database exec prisma studio",
    "db:seed": "pnpm --filter @gdms/database exec prisma db seed",
    "deploy:fast": "bash scripts/deploy-fast.sh web api",
    "deploy:all": "bash scripts/deploy-fast.sh web api worker automation"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
